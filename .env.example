# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/bank-churn-tracker?retryWrites=true&w=majority

# NextAuth secret – generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-to-a-long-random-secret

# Your app URL (use http://localhost:3000 for local dev)
NEXTAUTH_URL=http://localhost:3000

# Google OAuth credentials (from Google Cloud Console > APIs & Services > Credentials)
# Add http://localhost:3000 to Authorized JavaScript origins
# Add http://localhost:3000/api/auth/callback/google to Authorized redirect URIs
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
